{
  "name": "@futurelab-studio/telepi",
  "version": "0.4.1",
  "description": "Telegram bridge for the Pi coding agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benedict2310/TelePi.git"
  },
  "bugs": {
    "url": "https://github.com/benedict2310/TelePi/issues"
  },
  "homepage": "https://github.com/benedict2310/TelePi#readme",
  "keywords": [
    "telegram",
    "bot",
    "pi",
    "coding-agent",
    "voice",
    "handoff"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "telepi": "dist/cli.js"
  },
  "files": [
    "dist",
    "extensions/telepi-handoff.ts",
    "launchd/com.telepi.plist",
    "systemd/telepi.service",
    "README.md",
    ".env.example",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist artifacts",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "build:clean": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "package:release": "npm run build:clean && node scripts/package-release.mjs",
    "ci:release": "npm test && npm run package:release",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@mariozechner/pi-coding-agent": "0.70.2",
    "grammy": "^1.35.0",
    "minimatch": "^10.2.4"
  },
  "optionalDependencies": {
    "parakeet-coreml": "^2.2.0",
    "sherpa-onnx-node": "1.12.32"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
